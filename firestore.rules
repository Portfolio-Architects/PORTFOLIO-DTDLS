rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default rule: Allow public read, restrict writes to authenticated admins
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Allow users to read their own profile (if applicable)
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }
  }
}
